# ── LLM Configuration ──────────────────────────────────────────────────────
# API key for your LLM provider.
# • OpenAI / Anthropic-compatible cloud service → paste your key here
# • Ollama (local, no key needed)              → set to: ollama
LLM_API_KEY=your_api_key_here

# Base URL of the LLM API (must be OpenAI-compatible).
# OpenAI (default):   https://api.openai.com/v1
# Ollama (local):     http://localhost:11434/v1
# LM Studio (local):  http://localhost:1234/v1
LLM_BASE_URL=https://api.openai.com/v1

# Model name to use.
# OpenAI examples:  gpt-4o   gpt-4o-mini   gpt-3.5-turbo
# Ollama examples:  llama3   mistral        phi3
LLM_MODEL=gpt-4o-mini
