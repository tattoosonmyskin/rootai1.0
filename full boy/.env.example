# RootAI Local Configuration
# Copy this file to .env and fill in your values

# ── LLM Configuration ─────────────────────────────────────────────────────────
# API key for your LLM provider (OpenAI, Anthropic-compatible, etc.)
VITE_LLM_API_KEY=your_api_key_here

# Base URL for the LLM API (OpenAI-compatible endpoint)
# Default: https://api.openai.com/v1
# For Ollama (local): http://localhost:11434/v1
# For other providers: set their OpenAI-compatible endpoint
VITE_LLM_BASE_URL=https://api.openai.com/v1

# Model name to use
# OpenAI: gpt-4o, gpt-4o-mini, gpt-3.5-turbo
# Ollama: llama3, mistral, etc.
VITE_LLM_MODEL=gpt-4o-mini
